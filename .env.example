# Environment Variables Template for RentPro Backend
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/rentpro_db
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_long_random_secret_key_minimum_32_characters_long
JWT_TTL=86400000

# Rate Limiting Configuration
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_UPLOAD=10

# Logging Configuration (set to INFO or WARN in production)
SECURITY_LOG_LEVEL=INFO
SECURITY_ACCESS_LOG_LEVEL=INFO
SECURITY_AUTH_LOG_LEVEL=INFO
SECURITY_METHOD_LOG_LEVEL=INFO
SQL_LOG_LEVEL=WARN
SQL_BIND_LOG_LEVEL=WARN
SHOW_SQL=false
FORMAT_SQL=true

# Error Handling (set to 'never' in production)
ERROR_INCLUDE_MESSAGE=never
ERROR_INCLUDE_BINDING=never
ERROR_INCLUDE_STACKTRACE=never

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Storage Configuration
# local (default) stores files in local ./uploads/* directories
STORAGE_PROVIDER=local

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
S3_BUCKET=your_bucket_name
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
# Optional for S3-compatible vendors (R2, Spaces, MinIO, etc.)
S3_ENDPOINT=
# Optional explicit public base URL, e.g. https://cdn.example.com
S3_PUBLIC_BASE_URL=
S3_KEY_PREFIX=rentpro
S3_PATH_STYLE_ACCESS=true

# Security Headers Configuration
XSS_PROTECTION=true
CONTENT_TYPE_OPTIONS=true
FRAME_OPTIONS=DENY
HSTS=max-age=31536000; includeSubDomains

# Production Settings
# Uncomment these for production deployment
# SPRING_PROFILES_ACTIVE=prod
# SERVER_SSL_ENABLED=true
# SERVER_SSL_KEY_STORE=path/to/keystore.p12
# SERVER_SSL_KEY_STORE_PASSWORD=keystore_password
# SERVER_SSL_KEY_ALIAS=tomcat
